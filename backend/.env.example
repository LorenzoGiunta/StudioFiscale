# Variabili d'ambiente del backend.
# Copiare in un file locale NON versionato (es. .env) e impostarle nella
# configurazione di avvio (IntelliJ: Run > Edit Configurations > Environment variables,
# oppure export nel terminale prima di ./mvnw spring-boot:run).

# Database MySQL (DB_PASSWORD e' OBBLIGATORIA: nessun default nel codice)
DB_URL=jdbc:mysql://localhost:3306/gestionalec
DB_USER=root
DB_PASSWORD=root

# Segreto JWT — OBBLIGATORIO (nessun default nel codice: se manca, l'app non parte).
# Usare una stringa lunga e casuale (>= 32 caratteri / 256 bit per HS256).
JWT_SECRET=cambia-questo-segreto-con-una-stringa-random-lunga

# Email (Gmail App Password, NON la password normale dell'account)
# Lasciare EMAIL_ENABLED=false per disattivare l'invio in locale/demo.
EMAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
